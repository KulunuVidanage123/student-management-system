# =============================================================================
# NEXT.JS + TYPESCRIPT .GITIGNORE
# Optimized for student-management-system
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─────────────────────────────────────────────────────────────────────────────
# Next.js Build Output
# ─────────────────────────────────────────────────────────────────────────────
.next/
out/
build/
dist/
.vercel/

# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables (SECURITY: Never commit secrets)
# ─────────────────────────────────────────────────────────────────────────────
# Keep local env files private
.env.local
.env*.local

# Allow committing example/template files (optional)
!.env.example
!.env.template

# ─────────────────────────────────────────────────────────────────────────────
# TypeScript
# ─────────────────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# Testing & Coverage
# ─────────────────────────────────────────────────────────────────────────────
coverage/
*.coverage
.nyc_output/

# ─────────────────────────────────────────────────────────────────────────────
# IDEs & Editors
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ─────────────────────────────────────────────────────────────────────────────
# OS & System Files
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────────────────
# Logs & Debug
# ─────────────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─────────────────────────────────────────────────────────────────────────────
# Miscellaneous
# ─────────────────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx

# Temporary files
*.tmp
*.temp
*.bak
*.swp

